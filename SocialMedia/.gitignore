# -------------------------------------------------------------------
# System & OS Files (Never commit these across different platforms)
# -------------------------------------------------------------------
.DS_Store
Thumbs.db

# -------------------------------------------------------------------
# Environment Variables & Secrets (Crucial for security)
# -------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# -------------------------------------------------------------------
# Third-Party Dependencies (Downloadable via package managers)
# -------------------------------------------------------------------
node_modules/
bower_components/
vendor/
.venv/
env/

# -------------------------------------------------------------------
# Build Artifacts & Output Directories
# -------------------------------------------------------------------
dist/
build/
out/
bin/
obj/
*.exe
*.dll
*.so

# -------------------------------------------------------------------
# Logs, Caches, and Runtime Files
# -------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
.eslintcache
.cache/

# -------------------------------------------------------------------
# IDE & Text Editor Configuration Folders
# -------------------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
